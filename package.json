{
  "name": "realty-minibus",
  "version": "0.1.0",
  "private": true,
  "description": "Minsk real estate scraper (300-450 USD focus)",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "npm-run-all -p dev:backend dev:frontend",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm-run-all build:backend build:frontend",
    "build:backend": "npm --workspace backend run build",
    "build:frontend": "npm --workspace frontend run build",
    "test": "npm-run-all test:backend smoke",
    "test:backend": "npm --workspace backend run test",
    "test:e2e": "playwright test",
    "smoke": "node scripts/smoke.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "npm-run-all": "^4.1.5",
    "prisma": "^5.22.0"
  }
}
