{
  "name": "@realty-minibus/backend",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker:images": "tsx src/queue/image.worker.ts",
    "scrape:once": "tsx src/parsers/run-scrape.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.8.2",
    "bullmq": "^5.41.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "node-cron": "^4.2.1",
    "playwright": "^1.50.1",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "telegraf": "^4.16.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.17",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
